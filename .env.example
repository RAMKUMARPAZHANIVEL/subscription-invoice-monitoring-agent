# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb?schema=public

# GCP
GOOGLE_CLOUD_PROJECT=
GCP_REGION=

# Subscription invoice monitoring
INVOICE_CHECK_INTERVAL_CRON="0 */6 * * *"
INVOICE_ALERT_WEBHOOK_URL=

# AI provider (required for invoice data extraction)
ANTHROPIC_API_KEY=

# Gmail OAuth (domain-wide delegated service account credentials)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Mailbox to read invoice emails from
GMAIL_ADMIN_EMAIL=

# Attachment storage
# Bucket used to store invoice attachments when ATTACHMENT_STORE_DRIVER=gcs
GCS_BUCKET_NAME=
# Storage backend for attachments: "local" or "gcs" (default: gcs)
ATTACHMENT_STORE_DRIVER=gcs
