{
  "name": "subscription-invoice-monitoring-agent",
  "version": "0.1.0",
  "description": "AI agent that monitors subscription invoices, deployed on GCP Cloud Run.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@google-cloud/storage": "^7.21.0",
    "@prisma/client": "^7.8.0",
    "csv-parse": "^7.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.9.0",
    "googleapis": "^173.0.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.4"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
